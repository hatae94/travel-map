{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest",
    "node_modules/@xenova/transformers/.+\\.js$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "node_modules/(?!(@xenova/transformers)/)"
  ]
}
